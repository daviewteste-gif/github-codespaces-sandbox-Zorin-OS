{
  "name": "Ubuntu GNOME Completo - Docker",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "features": {
    "ghcr.io/devcontainers/features/desktop-lite:1": {}
  },
  "forwardPorts": [6080],
  "portsAttributes": {
    "6080": {
      "label": "noVNC - GNOME Desktop",
      "onAutoForward": "openPreview"
    }
  },
  "postCreateCommand": "echo 'Ambiente pronto! Acesse pela porta 6080'",
  "remoteUser": "vscode"
}
